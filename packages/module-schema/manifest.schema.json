{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://clerq.dev/schemas/module-manifest.json",
  "title": "Clerq Module Manifest",
  "description": "Manifest for a pluggable Clerq module (removable, integratable)",
  "type": "object",
  "required": [
    "id",
    "slug",
    "name",
    "version"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique module identifier (e.g. my-module)",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "slug": {
      "type": "string",
      "description": "Machine-readable slug, same as id typically",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "description": "Human-readable module name"
    },
    "version": {
      "type": "string",
      "description": "Semantic version or YYYY.Q (e.g. 0.1.0, 2026.1)",
      "pattern": "^(\\d+\\.\\d+(\\.\\d+)?|\\d{4}\\.\\d)$"
    },
    "description": {
      "type": "string",
      "description": "Short description of the module"
    },
    "entryPoints": {
      "type": "object",
      "description": "Entry points for UI, routes, task intents",
      "properties": {
        "ui": {
          "type": "string",
          "description": "Path to UI component (relative to module root)"
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Paths to route handler files"
        },
        "taskIntents": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Task intent names this module handles (e.g. rate, payroll)"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Capabilities this module provides"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Dependencies (e.g. clerq-core: >=0.1.0)"
    }
  },
  "additionalProperties": false
}