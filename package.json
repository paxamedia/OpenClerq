{
  "name": "clerq",
  "version": "0.1.0",
  "description": "Local administrative agent & model context server (MCS) — small desktop automation for generic clerical work.",
  "keywords": [
    "ai",
    "clerq"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paxamedia/OpenClerq.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:gateway": "pnpm --filter @clerq/gateway build",
    "build:desktop": "pnpm --filter @clerq/desktop build",
    "build:core": "cd packages/calculation-core && cargo build --release",
    "dev": "pnpm --filter @clerq/gateway dev",
    "dev:desktop": "pnpm --filter @clerq/desktop dev",
    "gateway": "pnpm --filter @clerq/gateway start",
    "desktop": "pnpm --filter @clerq/desktop tauri dev",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter @clerq/gateway test",
    "test:rust": "cd packages/calculation-core && cargo test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "build:installers": "pnpm build:sidecars && node scripts/build-desktop.js",
    "build:installers:local": "UNSET_CI=1 pnpm run build:installers",
    "build:sidecars": "node scripts/build-sidecars.js",
    "sync-version": "node scripts/sync-version.js",
    "release": "pnpm run sync-version && pnpm run build:installers"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "devDependencies": {
    "bun": "^1.3.10",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  }
}